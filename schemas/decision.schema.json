{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coding Flow Decision Add",
  "type": "object",
  "required": [
    "title",
    "status",
    "agent",
    "related",
    "context",
    "decision",
    "options",
    "pros",
    "cons",
    "consequences"
  ],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "rejected", "superseded"]
    },
    "agent": { "type": "string", "minLength": 1 },
    "related": { "type": "string" },
    "context": { "type": "string" },
    "decision": { "type": "string" },
    "options": { "type": "string" },
    "pros": { "type": "string" },
    "cons": { "type": "string" },
    "consequences": { "type": "string" }
  },
  "additionalProperties": false
}

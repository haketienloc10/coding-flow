{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stories Split Schema",
  "type": "object",
  "required": ["stories"],
  "properties": {
    "stories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "acceptance_criteria"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "files_to_change": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "additionalProperties": false
}

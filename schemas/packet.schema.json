{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Packet Schema",
  "type": "object",
  "required": ["goal", "scope", "global_acceptance_criteria"],
  "properties": {
    "goal": { "type": "string" },
    "scope": {
      "type": "object",
      "required": ["in", "out"],
      "properties": {
        "in": {
          "type": "array",
          "items": { "type": "string" }
        },
        "out": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "global_acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "technical_constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "shared_data_contracts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation_strategy": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}

{
  "type": "object",
  "required": ["mode", "status", "summary", "fixed_findings", "changed_files", "notes", "next"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["initial", "fix"]
    },
    "status": {
      "type": "string",
      "enum": ["ready_for_verify", "blocked", "partial", "failed"]
    },
    "summary": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fixed_findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next": {
      "type": "string",
      "enum": ["verify", "plan", "clarify", "none"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "ready_for_verify" } } },
      "then": { "properties": { "next": { "const": "verify" } } }
    }
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coding Flow Coding",
  "type": "object",
  "required": ["mode", "status", "summary", "fixed_findings", "changed_files", "notes", "next"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["initial", "fix"]
    },
    "status": {
      "type": "string",
      "enum": ["ready_for_verify", "blocked", "partial", "failed"]
    },
    "summary": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fixed_findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next": {
      "type": "string",
      "enum": ["verify", "plan", "clarify", "none"]
    }
  },
  "additionalProperties": false
}

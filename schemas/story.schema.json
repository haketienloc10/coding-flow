{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Story Schema",
  "type": "object",
  "required": ["title", "description", "acceptance_criteria"],
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string" },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files_to_change": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}

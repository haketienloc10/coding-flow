{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coding Flow Verify",
  "type": "object",
  "required": [
    "status",
    "checks",
    "manual_checks",
    "acceptance_criteria_checked",
    "findings",
    "known_issues",
    "done_criteria_verified"
  ],
  "properties": {
    "status": { "type": "string", "enum": ["passed", "failed", "partial", "skipped"] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command", "status"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "partial", "skipped"] },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "manual_checks": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria_checked": { "type": "array", "items": { "type": "string" } },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "type", "expected", "actual", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "blocking"]
          },
          "type": {
            "type": "string",
            "enum": [
              "acceptance_mismatch",
              "test_failure",
              "runtime_error",
              "copy_mismatch",
              "ui_mismatch",
              "regression",
              "missing_behavior",
              "other"
            ]
          },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "evidence": { "type": "string" },
          "suggested_fix": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "known_issues": { "type": "array", "items": { "type": "string" } },
    "done_criteria_verified": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "passed" } } },
      "then": { "properties": { "findings": { "maxItems": 0 } } }
    },
    {
      "if": { "properties": { "status": { "enum": ["failed", "partial"] } } },
      "then": { "properties": { "findings": { "minItems": 1 } } }
    }
  ],
  "additionalProperties": false
}

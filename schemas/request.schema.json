{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coding Flow Request Intake",
  "type": "object",
  "required": ["summary", "type", "planning_needed", "lane", "next_action"],
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": [
        "question",
        "unclear",
        "investigation",
        "new_feature",
        "bug_fix",
        "refactor",
        "maintenance",
        "documentation",
        "test_only"
      ]
    },
    "planning_needed": { "type": "boolean" },
    "lane": {
      "type": "string",
      "enum": ["none", "needs_clarification", "tiny", "normal", "high_risk"]
    },
    "risk_flags": { "type": "array", "items": { "type": "string" } },
    "hard_gates": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "clarifying_questions": { "type": "array", "items": { "type": "string" } },
    "next_action": {
      "type": "string",
      "enum": ["answer", "clarify", "investigate", "plan", "none"]
    }
  },
  "additionalProperties": false
}
